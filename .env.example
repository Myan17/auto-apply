# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Path to your service account credentials JSON (see README for how to get this)
GOOGLE_CREDENTIALS_PATH=./credentials.json

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS-PART>/edit
GOOGLE_SHEET_ID=your-sheet-id-here

# ── Applicant Info ────────────────────────────────────────────────────────────
APPLICANT_NAME=Your Full Name
APPLICANT_EMAIL=your@email.com
APPLICANT_PHONE=123-456-7890
APPLICANT_ADDRESS=123 Main St, Apt 1
APPLICANT_CITY=New York
APPLICANT_STATE=NY
APPLICANT_ZIP=10001

# ── Resume ────────────────────────────────────────────────────────────────────
# Absolute path to your base resume PDF
RESUME_PATH=/path/to/your/resume.pdf

# ── Workday account (optional) ────────────────────────────────────────────────
# Password auto-apply will use when creating Workday accounts
WORKDAY_PASSWORD=
